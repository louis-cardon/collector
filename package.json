{
  "name": "collector-shop",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w backend",
    "test:e2e:playwright": "npm run test:e2e -w frontend",
    "loadtest": "node scripts/load-tests/run-autocannon.mjs",
    "loadtest:catalog": "npm run loadtest -- --target catalog",
    "loadtest:login": "npm run loadtest -- --target login",
    "loadtest:summary": "node scripts/load-tests/summarize-autocannon.mjs --input load-test-results"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "concurrently": "^9.2.1"
  }
}

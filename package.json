{
  "name": "collector-shop",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "services/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w services/api-gateway\" \"npm run dev -w services/auth-service\" \"npm run dev -w services/catalog-service\" \"npm run dev -w services/article-service\" \"npm run dev -w services/audit-service\" \"npm run dev -w services/notification-service\"",
    "dev:microservices": "concurrently \"npm run dev -w services/api-gateway\" \"npm run dev -w services/auth-service\" \"npm run dev -w services/catalog-service\" \"npm run dev -w services/article-service\" \"npm run dev -w services/audit-service\" \"npm run dev -w services/notification-service\"",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down --remove-orphans",
    "compose:logs": "docker compose logs -f reverse-proxy frontend api-gateway auth-service catalog-service article-service audit-service notification-service",
    "compose:ps": "docker compose ps",
    "compose:seed": "docker compose --profile ops run --rm db-seed",
    "compose:observability:up": "docker compose --profile observability up -d",
    "compose:security:trivy": "docker compose --profile security run --rm trivy-fs",
    "compose:security:gitleaks": "docker compose --profile security run --rm gitleaks",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w frontend",
    "test:e2e:playwright": "npm run test:e2e -w frontend",
    "docker:build:api-gateway": "docker build -f services/api-gateway/Dockerfile -t collector/api-gateway:latest .",
    "docker:build:auth-service": "docker build -f services/auth-service/Dockerfile -t collector/auth-service:latest .",
    "docker:build:catalog-service": "docker build -f services/catalog-service/Dockerfile -t collector/catalog-service:latest .",
    "docker:build:article-service": "docker build -f services/article-service/Dockerfile -t collector/article-service:latest .",
    "docker:build:audit-service": "docker build -f services/audit-service/Dockerfile -t collector/audit-service:latest .",
    "docker:build:notification-service": "docker build -f services/notification-service/Dockerfile -t collector/notification-service:latest .",
    "loadtest": "node scripts/load-tests/run-autocannon.mjs",
    "loadtest:catalog": "npm run loadtest -- --target catalog",
    "loadtest:login": "npm run loadtest -- --target login",
    "loadtest:summary": "node scripts/load-tests/summarize-autocannon.mjs --input load-test-results",
    "docker:build:frontend": "docker build -f frontend/Dockerfile -t collector/frontend:latest .",
    "docker:build:microservices": "npm run docker:build:api-gateway && npm run docker:build:auth-service && npm run docker:build:catalog-service && npm run docker:build:article-service && npm run docker:build:audit-service && npm run docker:build:notification-service && npm run docker:build:frontend",
    "minikube:build-images": "powershell -ExecutionPolicy Bypass -File scripts\\minikube\\build-images.ps1",
    "k8s:apply:dev-local": "kubectl apply -k infra/k8s/overlays/dev-local",
    "k8s:apply:dev": "kubectl apply -k infra/k8s/overlays/dev",
    "k8s:apply:preprod": "kubectl apply -k infra/k8s/overlays/preprod",
    "k8s:apply:prod": "kubectl apply -k infra/k8s/overlays/prod",
    "k8s:secrets:dev": "powershell -ExecutionPolicy Bypass -File scripts\\k8s\\apply-secrets.ps1 -Environment dev",
    "k8s:secrets:preprod": "powershell -ExecutionPolicy Bypass -File scripts\\k8s\\apply-secrets.ps1 -Environment preprod",
    "k8s:secrets:prod": "powershell -ExecutionPolicy Bypass -File scripts\\k8s\\apply-secrets.ps1 -Environment prod",
    "argocd:install": "powershell -ExecutionPolicy Bypass -File scripts\\argocd\\install.ps1",
    "argocd:bootstrap:dev-local": "powershell -ExecutionPolicy Bypass -File scripts\\argocd\\bootstrap-dev-local.ps1",
    "argocd:bootstrap:dev": "powershell -ExecutionPolicy Bypass -File scripts\\argocd\\bootstrap-dev.ps1",
    "argocd:bootstrap:all-envs": "powershell -ExecutionPolicy Bypass -File scripts\\argocd\\bootstrap-all-envs.ps1",
    "argocd:ui": "powershell -ExecutionPolicy Bypass -File scripts\\argocd\\open-ui.ps1",
    "argocd:password": "powershell -ExecutionPolicy Bypass -File scripts\\argocd\\get-admin-password.ps1"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "concurrently": "^9.2.1"
  }
}

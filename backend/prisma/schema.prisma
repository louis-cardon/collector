generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  seller
  admin
}

enum ArticleStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum AuditAction {
  ITEM_APPROVED
  ITEM_REJECTED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  ACCESS_DENIED
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  passwordHash     String
  role             Role
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  articles         Article[]  @relation("SellerArticles")
  reviewedArticles Article[]  @relation("ReviewerArticles")
  auditLogs        AuditLog[] @relation("AuditActorLogs")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  articles  Article[]
}

model Article {
  id           String        @id @default(cuid())
  title        String
  description  String
  price        Decimal       @db.Decimal(10, 2)
  shippingCost Decimal       @db.Decimal(10, 2)
  status       ArticleStatus @default(PENDING_REVIEW)
  sellerId     String
  categoryId   String
  reviewedAt   DateTime?
  reviewedBy   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  seller       User          @relation("SellerArticles", fields: [sellerId], references: [id], onDelete: Restrict)
  reviewer     User?         @relation("ReviewerArticles", fields: [reviewedBy], references: [id], onDelete: SetNull)
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([sellerId])
  @@index([categoryId])
  @@index([reviewedBy])
  @@index([status])
}

model AuditLog {
  id           String      @id @default(cuid())
  action       AuditAction
  actorId      String?
  actorRole    Role?
  resourceType String
  resourceId   String?
  metadata     Json?
  timestamp    DateTime    @default(now())
  actor        User?       @relation("AuditActorLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([timestamp])
}

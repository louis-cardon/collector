# Copy this file to .env.k8s.dev-local, .env.k8s.dev, .env.k8s.preprod or .env.k8s.prod.
# Values in these files are ignored by Git via .gitignore.

POSTGRES_DB=collector
POSTGRES_USER=collector
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me
INTERNAL_SERVICE_TOKEN=change-me
RESEND_API_KEY=disabled
# Optional: override if your database host differs from the in-cluster postgres service.
# DATABASE_URL=postgresql://collector:change-me@postgres:5432/collector?schema=public
# Optional: override if Prisma should not reuse the postgres credentials above.
# PGDATABASE=collector
# PGUSER=collector
# PGPASSWORD=change-me
